if not game:IsLoaded() then 
    game.Loaded:Wait() 
end
print("autoplay") -- Oyun yüklendiği an konsola basar.

local Players = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")
local GuiService = game:GetService("GuiService")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- PERSISTENCE (Işınlanma Koruması)
if queue_on_teleport then
    queue_on_teleport([[loadstring(game:HttpGet("https://raw.githubusercontent.com/Bilmemi/SlapRoyale/refs/heads/main/Auto/Play"))()]])
end

local Settings = {
    HitboxSize = Vector3.new(8, 8, 8),
    MatchmakingID = 9426795465, 
    MapID = 9431156611,         
    AttackRange = 12,
    StuckThreshold = 3
}

local LastPos = Vector3.zero
local StuckTime = 0
local StrafeAngle = 0

--[ FONKSİYONLAR ]--

-- Her şeyi kuşanma (Tool/Handle Garantili)
local function equipEverything()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    if not char:FindFirstChildOfClass("Tool") then
        local tool = LocalPlayer.Backpack:FindFirstChildOfClass("Tool")
        if tool then
            hum:EquipTool(tool)
        end
    end
end

-- Agresif Hitbox Sistemi
local function applyHitbox()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            local hum = p.Character:FindFirstChild("Humanoid")
            if hrp and hum and hum.Health > 0 then
                hrp.Size = Settings.HitboxSize
                hrp.Transparency = 0.7
                hrp.CanCollide = false
                hrp.Massless = true
            end
        end
    end
end

-- Global Hedef Bulucu (Mesafe Sınırı Yok)
local function getGlobalTarget()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    
    local target, minDistance = nil, math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") then
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            if hrp and p.Character.Humanoid.Health > 0 then
                local dist = (hrp.Position - char.HumanoidRootPart.Position).Magnitude
                if dist < minDistance then
                    minDistance = dist
                    target = p.Character
                end
            end
        end
    end
    return target
end

--[ ANA DÖNGÜ ]--

RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") or not char:FindFirstChild("Humanoid") then return end
    
    local root = char.HumanoidRootPart
    local hum = char.Humanoid
    
    -- Ölüm ve Konum Kontrolü
    if hum.Health <= 0 or (game.PlaceId ~= Settings.MatchmakingID and game.PlaceId ~= Settings.MapID) then
        TeleportService:Teleport(Settings.MatchmakingID, LocalPlayer)
        return
    end

    -- Otobüs Atlayışı
    for _, obj in pairs(Workspace:GetChildren()) do
        if obj.Name:lower():find("bus") then
            local ev = game:GetService("ReplicatedStorage"):FindFirstChild("Events")
            local jump = ev and ev:FindFirstChild("BusJump")
            if jump then jump:FireServer() end
        end
    end

    applyHitbox()
    equipEverything()
    
    local target = getGlobalTarget()

    -- Anti-Stuck (3s)
    if (root.Position - LastPos).Magnitude < 0.2 then
        StuckTime = StuckTime + task.wait()
        if StuckTime > Settings.StuckThreshold then
            hum.Jump = true
            StuckTime = 0
        end
    else
        StuckTime = 0
    end
    LastPos = root.Position

    -- Hedef Takibi ve Saldırı
    if target then
        local tRoot = target.HumanoidRootPart
        local distance = (tRoot.Position - root.Position).Magnitude
        
        -- Aimbot Kamera
        Workspace.CurrentCamera.CFrame = CFrame.new(Workspace.CurrentCamera.CFrame.Position, tRoot.Position)

        -- KOŞ VE SALDIR
        if distance > Settings.AttackRange then
            hum:MoveTo(tRoot.Position) -- Mesafe ne olursa olsun direkt üstüne koş
        else
            -- Menzil içindeyse (12 birim) Strafe yaparak saldır
            StrafeAngle = StrafeAngle + 0.1
            local offset = Vector3.new(math.cos(StrafeAngle) * 7, 0, math.sin(StrafeAngle) * 7)
            hum:MoveTo(tRoot.Position + offset)
            
            local tool = char:FindFirstChildOfClass("Tool")
            if tool then tool:Activate() end
        end
    end
end)

-- Bağlantı Hatası Koruması
GuiService.ErrorMessageChanged:Connect(function()
    task.wait(2)
    TeleportService:Teleport(Settings.MatchmakingID, LocalPlayer)
end)
