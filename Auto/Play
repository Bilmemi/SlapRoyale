local LastPosition = Vector3.zero
local StuckTimer = 0
local StrafeAngle = 0


local function equipAnything()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local tool = char:FindFirstChildOfClass("Tool") or (LocalPlayer:FindFirstChild("Backpack") and LocalPlayer.Backpack:FindFirstChildOfClass("Tool"))
    
    if tool and tool.Parent ~= char and hum then
        hum:EquipTool(tool)
    end
end

local function teleportToMatchmaking()
    TeleportService:Teleport(Settings.MatchmakingID, LocalPlayer)
end

local function getBestTarget()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    
    local target, minDistance = nil, math.huge
    local myPos = char.HumanoidRootPart.Position

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") then
            local enemyHrp = p.Character:FindFirstChild("HumanoidRootPart")
            if enemyHrp and p.Character.Humanoid.Health > 0 then
                local dist = (enemyHrp.Position - myPos).Magnitude
                if dist < minDistance then
                    minDistance = dist
                    target = p.Character
                end
            end
        end
    end
    return target
end


