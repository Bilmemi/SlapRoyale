if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")
local GuiService = game:GetService("GuiService")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
local GroupID = 6409334 
local LastPosition = Vector3.zero
local StuckTimer = 0
local StrafeAngle = 0

local Settings = {
    HitboxSize = Vector3.new(10, 10, 10),
    AttackRange = 14,
    StuckThreshold = 2.5,
    PollRate = 0.05,
    MatchmakingID = 9426795465,
    MapID = 9431156611,
    ScriptURL = "https://raw.githubusercontent.com/Bilmemi/SlapRoyale/refs/heads/main/Auto/Play"
}

if typeof(queue_on_teleport) == "function" then
    queue_on_teleport(string.format([[loadstring(game:HttpGet("%s"))()]], Settings.ScriptURL))
end

local function checkStaff(player)
    if player == LocalPlayer then return end
    local success, rank = pcall(function() return player:GetRankInGroup(GroupID) end)
    if success and rank >= 10 then
        TeleportService:Teleport(Settings.MatchmakingID, LocalPlayer)
    end
end

Players.PlayerAdded:Connect(checkStaff)
for _, p in ipairs(Players:GetPlayers()) do checkStaff(p) end

local function autoLand(root)
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {LocalPlayer.Character}
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude

    local result = Workspace:Raycast(root.Position, Vector3.new(0, -2000, 0), raycastParams)
    if result and result.Instance then
        root.CFrame = CFrame.new(result.Position + Vector3.new(0, 3, 0))
    end
end

local function getBestTarget()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end

    local target, minDistance = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") then
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            if hrp and p.Character.Humanoid.Health > 0 then
                local dist = (hrp.Position - char.HumanoidRootPart.Position).Magnitude
                if dist < minDistance then
                    minDistance = dist
                    target = p.Character
                end
            end
        end
    end
    return target
end

local function mainLoop()
    local char = LocalPlayer.Character
    if not char then return end
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root or hum.Health <= 0 then return end

    local currentTool = char:FindFirstChildOfClass("Tool")
    if not currentTool then
        local backpackTool = LocalPlayer.Backpack:FindFirstChildOfClass("Tool")
        if backpackTool and not backpackTool.Name:lower():find("glider") then
            hum:EquipTool(backpackTool)
        end
    end

    local activeTool = char:FindFirstChildOfClass("Tool")
    if not activeTool or activeTool.Name:lower():find("glider") then return end

    if root.Position.Y > 50 then
        autoLand(root)
    end

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            p.Character.HumanoidRootPart.Size = Settings.HitboxSize
            p.Character.HumanoidRootPart.CanCollide = false
        end
    end

    if (root.Position - LastPosition).Magnitude < 0.3 then
        StuckTimer = StuckTimer + Settings.PollRate
        if StuckTimer >= Settings.StuckThreshold then hum.Jump = true StuckTimer = 0 end
    else
        StuckTimer = 0
    end
    LastPosition = root.Position

    local target = getBestTarget()
    if target and target:FindFirstChild("HumanoidRootPart") then
        local tRoot = target.HumanoidRootPart
        local dist = (tRoot.Position - root.Position).Magnitude

        root.CFrame = CFrame.lookAt(root.Position, Vector3.new(tRoot.Position.X, root.Position.Y, tRoot.Position.Z))
        
        StrafeAngle = StrafeAngle + 0.12
        local offset = Vector3.new(math.cos(StrafeAngle) * 7, 0, math.sin(StrafeAngle) * 7)
        hum:MoveTo(tRoot.Position + offset)

        if dist <= Settings.AttackRange then
            activeTool:Activate()
        end
    end
end

GuiService.ErrorMessageChanged:Connect(function()
    task.wait(2)
    TeleportService:Teleport(Settings.MatchmakingID, LocalPlayer)
end)

if game.PlaceId ~= Settings.MatchmakingID and game.PlaceId ~= Settings.MapID then
    TeleportService:Teleport(Settings.MatchmakingID, LocalPlayer)
end

task.spawn(function()
    while task.wait(Settings.PollRate) do
        pcall(mainLoop)
    end
end)

