local Settings = {
    HitboxSize = Vector3.new(10, 10, 10),
    MainLobbyID = 6403373529,    -- Slap Battles (Ana Menü)
    MatchmakingID = 9426795465, -- Slap Royale Matchmaking
    MapID = 9431156611,         -- Slap Royale (Savaş Alanı)
    AttackRange = 14,           
    ReactionSpeed = 0.01,
    StuckThreshold = 3          -- Talebin üzerine 3 saniye yapıldı
}

local CurrentTarget = nil
local LastPos = Vector3.zero
local StuckTime = 0
local StrafeAngle = 0

--[ FONKSİYONLAR ]--

-- FİZİKSEL TOKATLAMA (Tıklama Odaklı, Anti-Cheat Dostu)
local function physicalSlap()
    local char = LocalPlayer.Character
    if char then
        local tool = char:FindFirstChildOfClass("Tool")
        if tool then
            tool:Activate() 
        end
    end
end

-- Bot Hazırlık ve Otomatik Eldiven Kuşanma
local function isBotReady()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") or not char:FindFirstChild("Humanoid") then
        return false
    end
    
    local bp = LocalPlayer:FindFirstChild("Backpack")
    local tool = bp and bp:FindFirstChildOfClass("Tool") or char:FindFirstChildOfClass("Tool")
    
    if tool and not char:FindFirstChildOfClass("Tool") then
        char.Humanoid:EquipTool(tool)
    end
    
    return tool ~= nil
end

-- Otomatik Konum ve Lobi Kontrolü
local function checkLocation()
    local currentId = game.PlaceId
    if currentId ~= Settings.MatchmakingID and currentId ~= Settings.MapID then
        TeleportService:Teleport(Settings.MatchmakingID, LocalPlayer)
    end
end

