if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")
local GuiService = game:GetService("GuiService")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
local GroupID = 6409334 
local LastPosition = Vector3.zero
local StuckTimer = 0
local StrafeAngle = 0
local FallingTimer = 0
local JumpTimer = 0
local HasSlapped = false 

local Settings = {
    HitboxSize = Vector3.new(15, 15, 15),
    StuckThreshold = 2.5,
    PollRate = 0.05,
    MatchmakingID = 9426795465,
    MapID = 9431156611,
    ScriptURL = "https://raw.githubusercontent.com/Bilmemi/SlapRoyale/refs/heads/main/Auto/Play"
}

local function setupEnvironment()
    local al = Instance.new("Part", Workspace)
    al.Name = "AntiLava"
    al.Position = Vector3.new(-238, -43, 401)
    al.Size = Vector3.new(150, 30, 150)
    al.Anchored, al.Transparency, al.CanCollide = true, 1, false
end

local function bypassAntiCheat()
    local mt = getrawmetatable(game)
    local oldIndex = mt.__index
    setreadonly(mt, false)
    mt.__index = newcclosure(function(t, k)
        if not checkcaller() then
            if t:IsA("Humanoid") then
                if k == "WalkSpeed" then return 16 end
                if k == "JumpPower" or k == "JumpHeight" then return 50 end
            elseif t:IsA("Workspace") and k == "Gravity" then
                return 196.2
            end
        end
        return oldIndex(t, k)
    end)
    setreadonly(mt, true)
end

local function autoLoad()
    local sc = 'repeat task.wait() until game:IsLoaded(); loadstring(game:HttpGet("' .. Settings.ScriptURL .. '"))()'
    if syn and syn.queue_on_teleport then syn.queue_on_teleport(sc)
    elseif queue_on_teleport then queue_on_teleport(sc) end
end

local function handleDeath()
    TeleportService:Teleport(Settings.MatchmakingID, LocalPlayer)
end

local function setupCharacter(char)
    local hum = char:WaitForChild("Humanoid")
    hum.Died:Connect(handleDeath)
    hum:GetPropertyChangedSignal("Health"):Connect(function()
        if hum.Health <= 0 then handleDeath() end
    end)
    
    char.ChildAdded:Connect(function(child)
        if child:IsA("Tool") then
            local handle = child:FindFirstChild("Handle") or child:FindFirstChildOfClass("Part")
            if handle then
                handle.Touched:Connect(function(hit)
                    if hit.Name == "HumanoidRootPart" and hit.Parent:FindFirstChild("Humanoid") and hit.Parent ~= char then
                        HasSlapped = true
                        task.delay(0.5, function() HasSlapped = false end)
                    end
                end)
            end
        end
    end)
end

if LocalPlayer.Character then setupCharacter(LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(setupCharacter)

local function applyHitbox(targetChar)
    local hrp = targetChar:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.Size = Settings.HitboxSize
        hrp.Transparency = 0.7
        hrp.Color = Color3.new(0, 0, 0)
        hrp.Material = Enum.Material.Neon
        hrp.CanCollide = false
        hrp.CanTouch = true
    end
end

local function getBestTarget()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local target, minDistance = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") then
            local eh = p.Character.Humanoid
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            if hrp and eh.Health > 0 then
                applyHitbox(p.Character)
                local state = eh:GetState()
                if state ~= Enum.HumanoidStateType.Freefall and state ~= Enum.HumanoidStateType.Jumping and hrp.Velocity.Y < 5 and hrp.Velocity.Y > -5 then
                    local d = (hrp.Position - char.HumanoidRootPart.Position).Magnitude
                    if d < minDistance then minDistance, target = d, p.Character end
                end
            end
        end
    end
    return target
end

local function mainLoop()
    local char = LocalPlayer.Character
    if not char then return end
    local hum, root = char:FindFirstChildOfClass("Humanoid"), char:FindFirstChild("HumanoidRootPart")
    if not hum or not root or hum.Health <= 0 then return end

    JumpTimer = JumpTimer + Settings.PollRate
    if JumpTimer >= 1 then
        JumpTimer = 0
        if math.random(1, 100) <= 50 then hum.Jump = true end
    end

    local activeTool = char:FindFirstChildOfClass("Tool")
    if not activeTool then
        local bpt = LocalPlayer.Backpack:FindFirstChildOfClass("Tool")
        if bpt then hum:EquipTool(bpt) end
        return
    end

    local target = getBestTarget()
    if target and target:FindFirstChild("HumanoidRootPart") then
        local tr = target.HumanoidRootPart
        local dist = (tr.Position - root.Position).Magnitude

        root.CFrame = root.CFrame:Lerp(CFrame.lookAt(root.Position, Vector3.new(tr.Position.X, root.Position.Y, tr.Position.Z)), 0.15)
        
        if dist <= 15 then 
            activeTool:Activate()
        end

        if HasSlapped then
            StrafeAngle = StrafeAngle + 0.1
            local strafePos = tr.Position + Vector3.new(math.cos(StrafeAngle) * 10, 0, math.sin(StrafeAngle) * 10)
            hum:MoveTo(strafePos)
        else
            hum:MoveTo(tr.Position)
        end
    end
end

autoLoad()
bypassAntiCheat()
setupEnvironment()

GuiService.ErrorMessageChanged:Connect(function()
    task.wait(2)
    TeleportService:Teleport(Settings.MatchmakingID, LocalPlayer)
end)

if game.PlaceId ~= Settings.MatchmakingID and game.PlaceId ~= Settings.MapID then
    TeleportService:Teleport(Settings.MatchmakingID, LocalPlayer)
end

task.spawn(function()
    while task.wait(Settings.PollRate) do pcall(mainLoop) end
end)

print("Slap Royale Auto-Play Active")
