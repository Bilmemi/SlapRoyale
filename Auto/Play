if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")
local GuiService = game:GetService("GuiService")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
local GroupID = 6409334 
local LastPosition = Vector3.zero
local StuckTimer = 0
local StrafeAngle = 0
local FallingTimer = 0

local Settings = {
    HitboxSize = Vector3.new(10, 10, 10),
    AttackRange = 14,
    StuckThreshold = 2.5,
    PollRate = 0.05,
    MatchmakingID = 9426795465,
    MapID = 9431156611,
    ScriptURL = "https://raw.githubusercontent.com/Bilmemi/SlapRoyale/refs/heads/main/Auto/Play"
}

local function setupEnvironment()
    local al = Instance.new("Part", Workspace)
    al.Name = "AntiLava"
    al.Position = Vector3.new(-238, -43, 401)
    al.Size = Vector3.new(150, 30, 150)
    al.Anchored, al.Transparency, al.CanCollide = true, 1, false

    local aa = Instance.new("Part", al)
    aa.Name = "AntiAcid"
    aa.Position = Vector3.new(-70, -20, -725)
    aa.Size = Vector3.new(155, 35, 144)
    aa.Anchored, aa.Transparency, aa.CanCollide = true, 1, false
end

local function bypassAntiCheat()
    local mt = getrawmetatable(game)
    local oldIndex = mt.__index
    local oldNewIndex = mt.__newindex
    setreadonly(mt, false)

    mt.__index = newcclosure(function(t, k)
        if checkcaller() then return oldIndex(t, k) end
        if t:IsA("Humanoid") then
            if k == "WalkSpeed" then return 16 end
            if k == "JumpPower" or k == "JumpHeight" then return 50 end
        elseif t:IsA("Workspace") and k == "Gravity" then
            return 196.2
        end
        return oldIndex(t, k)
    end)

    mt.__newindex = newcclosure(function(t, k, v)
        if not checkcaller() and t:IsA("Humanoid") then
            if k == "WalkSpeed" or k == "JumpPower" or k == "JumpHeight" then return end
        end
        return oldNewIndex(t, k, v)
    end)
    setreadonly(mt, true)
end

local function autoLoad()
    local scriptContent = 'loadstring(game:HttpGet("' .. Settings.ScriptURL .. '"))()'
    if syn and syn.queue_on_teleport then syn.queue_on_teleport(scriptContent)
    elseif queue_on_teleport then queue_on_teleport(scriptContent) end
end

local function checkStaff(player)
    if player == LocalPlayer then return end
    local s, r = pcall(function() return player:GetRankInGroup(GroupID) end)
    if s and r >= 10 then TeleportService:Teleport(Settings.MatchmakingID, LocalPlayer) end
end

local function getBestTarget()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local target, minDistance = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") then
            local eh = p.Character.Humanoid
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            if hrp and eh.Health > 0 and eh:GetState() ~= Enum.HumanoidStateType.Freefall and hrp.Velocity.Y < 5 then
                local d = (hrp.Position - char.HumanoidRootPart.Position).Magnitude
                if d < minDistance then minDistance, target = d, p.Character end
            end
        end
    end
    return target
end

local function mainLoop()
    local char = LocalPlayer.Character
    if not char then return end
    local hum, root = char:FindFirstChildOfClass("Humanoid"), char:FindFirstChild("HumanoidRootPart")
    local rv = char:FindFirstChild("Ragdolled")
    if not hum or not root or hum.Health <= 0 then return end

    local currentTool = char:FindFirstChildOfClass("Tool")
    if not currentTool then
        local bpt = LocalPlayer.Backpack:FindFirstChildOfClass("Tool")
        if bpt then hum:EquipTool(bpt) end
    end

    local activeTool = char:FindFirstChildOfClass("Tool")
    if not activeTool or activeTool.Name:lower():find("glider") then 
        Workspace.Gravity = 196.2
        return 
    end

    local ir, ifall = (rv and rv.Value == true), (hum:GetState() == Enum.HumanoidStateType.Freefall or root.Velocity.Y < -5)
    FallingTimer = ifall and (FallingTimer + Settings.PollRate) or 0
    Workspace.Gravity = (ir or FallingTimer > 1.5) and 1000 or 196.2

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            p.Character.HumanoidRootPart.Size, p.Character.HumanoidRootPart.CanCollide = Settings.HitboxSize, false
        end
    end

    if (root.Position - LastPosition).Magnitude < 0.2 then
        StuckTimer = StuckTimer + Settings.PollRate
        if StuckTimer >= Settings.StuckThreshold then hum.Jump, StuckTimer = true, 0 end
    else StuckTimer = 0 end
    LastPosition = root.Position

    local target = getBestTarget()
    if target and target:FindFirstChild("HumanoidRootPart") then
        local tr = target.HumanoidRootPart
        root.CFrame = root.CFrame:Lerp(CFrame.lookAt(root.Position, Vector3.new(tr.Position.X, root.Position.Y, tr.Position.Z)), 0.3)
        StrafeAngle = StrafeAngle + 0.12
        hum:MoveTo(tr.Position + Vector3.new(math.cos(StrafeAngle) * 7, 0, math.sin(StrafeAngle) * 7))
        if (tr.Position - root.Position).Magnitude <= Settings.AttackRange then activeTool:Activate() end
    end
end

autoLoad()
bypassAntiCheat()
setupEnvironment()
Players.PlayerAdded:Connect(checkStaff)
for _, p in ipairs(Players:GetPlayers()) do checkStaff(p) end

GuiService.ErrorMessageChanged:Connect(function()
    task.wait(2)
    TeleportService:Teleport(Settings.MatchmakingID, LocalPlayer)
end)

if game.PlaceId ~= Settings.MatchmakingID and game.PlaceId ~= Settings.MapID then
    TeleportService:Teleport(Settings.MatchmakingID, LocalPlayer)
end

task.spawn(function()
    while task.wait(Settings.PollRate) do pcall(mainLoop) end
end)

print("Slap Royale Auto-Play Active")
