    hum:SetStateEnabled(Enum.HumanoidStateType.Swimming, false)

    JumpTimer = JumpTimer + Settings.PollRate
    if JumpTimer >= 1 then
        JumpTimer = 0
        if math.random(1, 100) <= 40 then
            hum.Jump = true
        end
    end

    local currentTool = char:FindFirstChildOfClass("Tool")
    if not currentTool then
        local bpt = LocalPlayer.Backpack:FindFirstChildOfClass("Tool")
        if bpt then hum:EquipTool(bpt) end
    end

    local activeTool = char:FindFirstChildOfClass("Tool")
    if not activeTool or activeTool.Name:lower():find("glider") then 
        Workspace.Gravity = 196.2
        return 
    end

    local ir, ifall = (rv and rv.Value == true), (hum:GetState() == Enum.HumanoidStateType.Freefall or root.Velocity.Y < -5)
    FallingTimer = ifall and (FallingTimer + Settings.PollRate) or 0
    Workspace.Gravity = (ir or FallingTimer > 1.5) and 1000 or 196.2

    if (root.Position - LastPosition).Magnitude < 0.2 then
        StuckTimer = StuckTimer + Settings.PollRate
        if StuckTimer >= Settings.StuckThreshold then hum.Jump, StuckTimer = true, 0 end
    else StuckTimer = 0 end
    LastPosition = root.Position

    local target = getBestTarget()
    if target and target:FindFirstChild("HumanoidRootPart") then
        local tr = target.HumanoidRootPart
        local dist = (tr.Position - root.Position).Magnitude
        local hSize = Settings.HitboxSize.X / 2 

        local lookTarget = Vector3.new(tr.Position.X, root.Position.Y, tr.Position.Z)
        root.CFrame = root.CFrame:Lerp(CFrame.lookAt(root.Position, lookTarget), 0.05)
        
        StrafeAngle = StrafeAngle + 0.02
        local strafeOffset = Vector3.new(math.cos(StrafeAngle) * (hSize * 0.5), 0, math.sin(StrafeAngle) * (hSize * 0.5))
        local targetPos = tr.Position + strafeOffset
        
        if dist > (hSize + 1) then
            hum:MoveTo(targetPos)
        elseif dist < (hSize - 1.5) then
            hum:MoveTo(root.Position + (root.Position - tr.Position).Unit * 4)
        else
            hum:MoveTo(root.Position)
        end
        
        local touching = false
        local parts = root:GetTouchingParts()
        for i = 1, #parts do
            if parts[i] == tr then touching = true break end
        end

        if touching and (tick() - lastAttack) > 0.35 then
            activeTool:Activate()
            lastAttack = tick()
        end
    end
end

