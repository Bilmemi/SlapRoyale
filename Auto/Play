task.spawn(function()
    while task.wait(Settings.ReactionSpeed) do
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then continue end
        
        local root = char.HumanoidRootPart
        local hum = char.Humanoid
        
        equipAnything()
        local currentTool = char:FindFirstChildOfClass("Tool")
        if not currentTool then continue end

        
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local eHrp = p.Character.HumanoidRootPart
                eHrp.Size = Settings.HitboxSize
                eHrp.Transparency = 0.7
                eHrp.CanCollide = false
            end
        end

        
        local bus = Workspace:FindFirstChild("Bus") or Workspace:FindFirstChild("BusModel")
        if bus then
            local jumpEvent = ReplicatedStorage:FindFirstChild("Events") and (ReplicatedStorage.Events:FindFirstChild("BusJump") or ReplicatedStorage.Events:FindFirstChild("Jump"))
            if jumpEvent then jumpEvent:FireServer() end
        end

        
        if (root.Position - LastPosition).Magnitude < 0.5 then
            StuckTimer = StuckTimer + Settings.ReactionSpeed
            if StuckTimer >= Settings.StuckThreshold then
                hum.Jump = true
                StuckTimer = 0
            end
        else
            StuckTimer = 0
        end
        LastPosition = root.Position

        
        local target = getBestTarget()
        if target and target:FindFirstChild("HumanoidRootPart") then
            local tHrp = target.HumanoidRootPart
            local dist = (tHrp.Position - root.Position).Magnitude

            
            local targetLookPos = Vector3.new(tHrp.Position.X, root.Position.Y, tHrp.Position.Z)
            root.CFrame = CFrame.lookAt(root.Position, targetLookPos)

            
            StrafeAngle = StrafeAngle + 0.1
            local moveOffset = Vector3.new(math.cos(StrafeAngle) * 7, 0, math.sin(StrafeAngle) * 7)
            hum:MoveTo(tHrp.Position + moveOffset)

            
            if dist <= Settings.AttackRange then
                currentTool:Activate()
                if math.random(1, 8) == 1 then hum.Jump = true end
            end
        end
    end
end)


